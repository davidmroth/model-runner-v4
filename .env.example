# model-runner-v4 — Lucebox Hub engine only (proxy/AgentLens/watchdog → ai-platform)
# Copy to .env and set HF_TOKEN only. All other values are safe to commit.

HF_TOKEN=

# Shared weights store (sibling under ~/projects/models-cache)
MODEL_DIR=../models-cache

LUCEBOX_IMAGE=ghcr.io/luce-org/lucebox-hub:cuda12

# Lucebox target must be non-MTP GGUF (v3 BeeLlama uses unsloth-mtp-q4km/ separately).
DFLASH_TARGET=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/unsloth-q4km/Qwen3.6-27B-Q4_K_M.gguf
DFLASH_DRAFT=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/dflash-lucebox/dflash-draft-3.6-q4_k_m.gguf
# 32k leaves VRAM for prefix snapshots on 2×24GB (131k starves KV cache).
DFLASH_MAX_CTX=131072

# Dual RTX 3090: layer-split target across both GPUs, draft on GPU1
GPU_COUNT=2
DFLASH_TARGET_GPU=0
DFLASH_DRAFT_GPU=1

# Spec-decode tuning (tool-split / single-GPU target mode).
# Colocating the draft with the target (DFLASH_DRAFT_GPU=0) removes the
# ~10ms/step cross-GPU logits bridge — fastest decode on 2×3090 when the
# target fits on one card. If the draft must live on the other GPU, set
# DFLASH_DRAFT_FEATURE_MIRROR=1 (avoids ~700ms/step feature copies).
DFLASH_DDTREE_BUDGET=22
DFLASH27B_DRAFT_CTX_MAX=2048
DFLASH_DRAFT_FEATURE_MIRROR=0
DFLASH27B_FA_WINDOW=0
DFLASH27B_KV_TQ3=1
DFLASH_LAYER_SPLIT=1
DFLASH_TARGET_DEVICES=cuda:0,cuda:1
DFLASH_TARGET_LAYER_SPLIT=32,32
DFLASH_PEER_ACCESS=1

# PFlash prefill — OFF by default for Hermes agent/cron workloads.
# Lossy 10:1 compress discards job instructions and causes mid-task failures
# (see docs/feedback-pflash-agent-regression.md). Opt in via enable-pflash*.sh.
DFLASH_PREFILL_MODE=off
DFLASH_PREFILL_DRAFTER=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/pflash/Qwen3-0.6B-BF16.gguf
DFLASH_PREFILL_THRESHOLD=3000
DFLASH_PREFILL_KEEP=0.10
DFLASH_LAZY=0

# Tool-split cache — OFF by default until prefix-cache restore is safe for mixed workloads.
# Enabling tool-split with prefix cache can restore stale benchmark KV (HumanEval) and yield
# empty or code-only responses — see docs/feedback-prefix-cache-regression.md.
# Profile: auto | qwen3 | laguna | plugin:name
DFLASH_TOOL_SPLIT_ENABLED=0
DFLASH_TOOL_SPLIT_PROFILE=auto
# DFLASH_TOOL_SPLIT_PLUGIN_DIR=/opt/lucebox/tool_split_plugins
DFLASH_TOOL_SPLIT_PINNED_SLOTS=2
DFLASH_TOOL_SPLIT_COMPRESS_CONV=0

# Optional PFlash (one-shot / bench only): ./scripts/enable-pflash.sh or enable-pflash-agent.sh
