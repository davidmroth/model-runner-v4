# model-runner-v4 — Lucebox Hub engine only (proxy/AgentLens/watchdog → ai-platform)
# Copy to .env and set HF_TOKEN only. All other values are safe to commit.

HF_TOKEN=

# Shared weights store (sibling under ~/projects/models-cache)
MODEL_DIR=../models-cache

LUCEBOX_IMAGE=ghcr.io/luce-org/lucebox-hub:cuda12

# Lucebox target must be non-MTP GGUF (v3 BeeLlama uses unsloth-mtp-q4km/ separately).
DFLASH_TARGET=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/unsloth-q4km/Qwen3.6-27B-Q4_K_M.gguf
DFLASH_DRAFT=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/dflash-lucebox/dflash-draft-3.6-q4_k_m.gguf
# 32k leaves VRAM for prefix snapshots on 2×24GB (131k starves KV cache).
DFLASH_MAX_CTX=131072

# Dual RTX 3090: layer-split target across both GPUs, draft on GPU1
GPU_COUNT=2
DFLASH_TARGET_GPU=0
DFLASH_DRAFT_GPU=1

# Spec-decode tuning (tool-split / single-GPU target mode).
# Colocating the draft with the target (DFLASH_DRAFT_GPU=0) removes the
# ~10ms/step cross-GPU logits bridge — fastest decode on 2×3090 when the
# target fits on one card. If the draft must live on the other GPU, set
# DFLASH_DRAFT_FEATURE_MIRROR=1 (avoids ~700ms/step feature copies).
DFLASH_DDTREE_BUDGET=22
DFLASH27B_DRAFT_CTX_MAX=2048
DFLASH_DRAFT_FEATURE_MIRROR=0
DFLASH27B_FA_WINDOW=0
DFLASH27B_KV_TQ3=1
DFLASH_LAYER_SPLIT=1
DFLASH_TARGET_DEVICES=cuda:0,cuda:1
DFLASH_TARGET_LAYER_SPLIT=32,32
DFLASH_PEER_ACCESS=1

# PFlash prefill — OFF by default for Hermes agent/cron workloads.
# Lossy 10:1 compress discards job instructions and causes mid-task failures
# (see docs/feedback-pflash-agent-regression.md). Opt in via enable-pflash*.sh.
DFLASH_PREFILL_MODE=off
DFLASH_PREFILL_DRAFTER=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/pflash/Qwen3-0.6B-BF16.gguf
DFLASH_PREFILL_THRESHOLD=3000
DFLASH_PREFILL_KEEP=0.10
DFLASH_LAZY=0

# Tool-split cache — ON when lucebox-hub has session-scoped prefix cache (July 2026+).
# Requires X-Conversation-Id on multi-turn agent traffic (proxy/Hermes send this).
# Without conversation id, each request is ephemeral-scoped (safe, no cross-session reuse).
# Profile: auto | qwen3 | laguna | plugin:name
DFLASH_TOOL_SPLIT_ENABLED=1
DFLASH_TOOL_SPLIT_PROFILE=auto
# DFLASH_TOOL_SPLIT_PLUGIN_DIR=/opt/lucebox/tool_split_plugins
DFLASH_TOOL_SPLIT_PINNED_SLOTS=2
DFLASH_TOOL_SPLIT_COMPRESS_CONV=0

# Native mmproj vision (requires build-mmproj dflash_server — see docs/vision-integration.md)
LUCEBOX_DFLASH_BUILD=../lucebox-hub-src/server/build-mmproj
DFLASH_SERVER_BIN=/opt/lucebox-hub/dflash-build/dflash_server
DFLASH_DAEMON_BIN=/opt/lucebox-hub/dflash-build/test_dflash
DFLASH_MMPROJ=/opt/lucebox-hub/server/models/qwen3.6-27b-gguf/mmproj-F16.gguf
DFLASH_MMPROJ_NO_OFFLOAD=1
DFLASH_MMPROJ_THREADS=4
IMAGE_MIN_TOKENS=1024
IMAGE_MAX_TOKENS=1024

# Optional PFlash (one-shot / bench only): ./scripts/enable-pflash.sh or enable-pflash-agent.sh

# P0b handler reliability (server_tools.py)
# Max seconds to wait for the single-flight daemon lock before returning 503.
# Unset = DFLASH_REQUEST_WALL_TIMEOUT_SEC; 0 = unbounded queue (no 503 on busy).
DFLASH_DAEMON_LOCK_WAIT_SEC=0
# Cap lock wait for real conversation traffic when DFLASH_DAEMON_LOCK_WAIT_SEC=0.
# Must exceed the longest expected cold prefill (90s at 20K tokens without PFlash).
DFLASH_SCOPED_LOCK_WAIT_SEC=180
# Bench/ephemeral traffic (no X-Conversation-Id) fails fast when lock is busy.
DFLASH_EPHEMERAL_LOCK_WAIT_SEC=5
# Scoped conversation traffic jumps ahead of ephemeral in the daemon lock queue.
DFLASH_SCOPED_LOCK_PRIORITY=1
# Max wall time for one streaming/non-streaming inference request.
DFLASH_REQUEST_WALL_TIMEOUT_SEC=600
# Thick conversation prefix slots for tool-split RESTORE_CHAIN (layer-split).
DFLASH_PREFIX_CACHE_SLOTS=2
# Skip SNAPSHOT_THIN above this KV depth when inline pin fails (daemon may crash).
DFLASH_TOOL_SNAPSHOT_MAX_KV=16384
# Phase 1c: pin tool KV via inline snap= on cold prefill (avoids SNAPSHOT_THIN at 20K+).
DFLASH_TOOL_INLINE_SNAP_PIN=1
# Suppress uvicorn access lines for GET /health and GET /v1/models (default on).
# Set to 0 to show probe traffic in docker logs (debug only).
DFLASH_QUIET_ACCESS_LOGS=1
